<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>¿volvemos</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: sans-serif;
      background: #fff0f5;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      padding: 3rem 2rem;
      text-align: center;
    }

    .heart {
      font-size: 80px;
      animation: pulse 1.2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.15); }
    }

    .pregunta {
      font-size: 32px;
      font-weight: 600;
      color: #333;
    }

    .botones {
      display: flex;
      gap: 1.5rem;
    }

    .btn {
      padding: 12px 40px;
      font-size: 18px;
      font-weight: 600;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      transition: transform 0.1s, opacity 0.15s;
    }

    .btn:active { transform: scale(0.96); }

    .btn-si {
      background: #EA4C89;
      color: #fff;
    }

    .btn-si:hover { opacity: 0.88; }

    .btn-no {
      background: #e0e0e0;
      color: #333;
    }

    .btn-no:hover { background: #d0d0d0; }

    /* Pantalla feliz */
    .feliz {
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      animation: fadeIn 0.4s ease;
    }

    .feliz.visible { display: flex; }

    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.9); }
      to   { opacity: 1; transform: scale(1); }
    }

    .feliz-title { font-size: 28px; font-weight: 700; color: #EA4C89; }
    .feliz-sub   { font-size: 16px; color: #666; }

    /* Overlay de error */
    .error-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      align-items: center;
      justify-content: center;
      z-index: 100;
    }

    .error-overlay.visible { display: flex; }

    .error-box {
      background: #fff;
      border: 2px solid #f44336;
      border-radius: 16px;
      padding: 2rem 2.5rem;
      max-width: 380px;
      width: 90%;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }

    .error-icon  { font-size: 56px; }
    .error-title { font-size: 20px; font-weight: 700; color: #c62828; }
    .error-msg   { font-size: 14px; color: #555; line-height: 1.6; }

    .error-code {
      font-family: monospace;
      font-size: 12px;
      background: #ffebee;
      color: #b71c1c;
      padding: 8px 14px;
      border-radius: 8px;
      width: 100%;
      text-align: left;
      line-height: 1.6;
    }

    .btn-cerrar {
      padding: 10px 28px;
      font-size: 14px;
      font-weight: 600;
      border-radius: 10px;
      border: none;
      background: #e0e0e0;
      color: #333;
      cursor: pointer;
    }

    .btn-cerrar:hover { background: #d0d0d0; }
  </style>
</head>
<body>

  <!-- Pantalla principal -->
  <div class="container" id="main">
    <div class="heart">❤️</div>
    <p class="pregunta">¿Me quieres?</p>
    <div class="botones">
      <button class="btn btn-si" onclick="responderSi()">Sí</button>
      <button class="btn btn-no" onclick="responderNo()">No</button>
    </div>
  </div>

  <!-- Pantalla feliz -->
  <div class="container feliz" id="feliz">
    <div style="font-size: 80px">🥰</div>
    <p class="feliz-title">¡Sabía que sí!</p>
    <p class="feliz-sub">yo tmbbbb 💕</p>
  </div>

  <!-- Error overlay -->
  <div class="error-overlay" id="errorOverlay">
    <div class="error-box">
      <div class="error-icon">🚨</div>
      <p class="error-title">Error 403: Respuesta no permitida</p>
      <p class="error-msg">La opción seleccionada viola los términos y condiciones del corazón. Esta acción ha sido registrada.</p>
      <div class="error-code">
        Uncaught TypeError: cannot return false<br>
        &nbsp;&nbsp;&nbsp;&nbsp;at heart.js:1:42
      </div>
      <button class="btn-cerrar" onclick="cerrarError()">Aceptar y reconsiderar</button>
    </div>
  </div>

  <script>
    function responderSi() {
      document.getElementById('main').style.display = 'none';
      document.getElementById('feliz').classList.add('visible');
    }

    function responderNo() {
      document.getElementById('errorOverlay').classList.add('visible');
    }

    function cerrarError() {
      document.getElementById('errorOverlay').classList.remove('visible');
    }
  </script>

</body>
</html>
